# ==============================================================================
# SpineSurge Pro Production Build Environment Variables
# ==============================================================================
# DO NOT COMMIT REAL VALUES TO SOURCE CONTROL
# ==============================================================================

# --- macOS Signing & Notarization ---
# Apple ID (usually your email)
APPLE_ID=your-apple-id@example.com
# App-specific password (generated at appleid.apple.com)
APPLE_APP_SPECIFIC_PASSWORD=your-app-specific-password
# Apple Team ID (found in Developer Account membership)
APPLE_TEAM_ID=your-team-id

# --- Windows Signing ---
# Path to P12/PFX certificate file (or base64 string)
CSC_LINK=/path/to/certificate.p12
# Password for the certificate
CSC_KEY_PASSWORD=your-certificate-password

# --- Build Environment ---
# GitHub Token for publishing releases (if using CI)
GH_TOKEN=your-github-personal-access-token
